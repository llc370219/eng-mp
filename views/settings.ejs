<%- include("header") %>
<h2>⚙️ 设置</h2>
<% if (msg) { %>
  <div class="msg msg-ok"><%= msg %></div>
<% } %>
<form method="POST" action="/demo/settings">
  <div class="card">
    <h2>阅读设置</h2>
    <div class="form-row" style="display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid #E5E7EB">
      <div>
        <div style="font-weight:500;font-size:14px">分句标注</div>
        <div style="font-size:12px;color:#6B7280">每个句子下方显示不同颜色的下划线</div>
      </div>
      <label style="position:relative;display:inline-block;width:44px;height:24px">
        <input type="checkbox" name="sentenceHighlight" <%= user.preferences && user.preferences.sentenceHighlight !== false ? 'checked' : '' %> style="opacity:0;width:0;height:0">
        <span style="position:absolute;cursor:pointer;top:0;left:0;right:0;bottom:0;background:#D1D5DB;border-radius:12px;transition:0.3s">
          <span style="position:absolute;content:'';height:18px;width:18px;left:3px;bottom:3px;background:white;border-radius:50%;transition:0.3s"></span>
        </span>
      </label>
    </div>
  </div>
  <div class="card">
    <h2>学习目标</h2>
    <div class="form-row">
      <label>每日学习目标（分钟）</label>
      <input type="number" name="dailyGoalMin" value="<%= user.preferences ? user.preferences.dailyGoalMin || 30 : 30 %>" min="5" max="480">
    </div>
  </div>
  <button type="submit" class="btn btn-primary" style="padding:12px 32px">保存设置</button>
</form>

<style>
  .form-row { margin-bottom: 12px; }
  .form-row label { display: block; font-size: 13px; font-weight: 500; margin-bottom: 4px; }
  .form-row input[type="number"] { width: 120px; padding: 8px 12px; border: 1px solid #D1D5DB; border-radius: 6px; font-size: 14px; }
  input:checked + span { background: #4F46E5; }
  input:checked + span > span { transform: translateX(20px); }
</style>
<%- include("footer") %>
