<a href="/demo/vocab" style="color:#4F46E5;text-decoration:none;font-size:14px">← 返回生词本</a>
<h2 style="margin-top:12px">📖 复习单词</h2>
<% if (msg) { %>
  <div class="card" style="text-align:center;color:#6B7280"><%= msg %></div>
<% } %>
<% if (vocabs.length) { %>
  <div class="card" style="text-align:center">
    <div style="font-size:12px;color:#6B7280">1 / <%= vocabs.length %></div>
    <div style="font-size:32px;font-weight:700;margin:16px 0"><%= vocabs[0].word %></div>
    <div style="color:#6B7280;font-size:16px"><%= vocabs[0].phonetic || '' %></div>
    <div style="font-size:18px;margin:16px 0"><%= vocabs[0].definition || '' %></div>
    <form method="POST" action="/demo/vocab/review/<%= vocabs[0]._id %>" style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-top:16px">
      <button type="submit" name="quality" value="0" class="btn" style="background:#FEE2E2;color:#DC2626">😵 不认识</button>
      <button type="submit" name="quality" value="2" class="btn" style="background:#FEF3C7;color:#D97706">😰 模糊</button>
      <button type="submit" name="quality" value="3" class="btn" style="background:#FEF9C3;color:#CA8A04">🤔 费力</button>
      <button type="submit" name="quality" value="4" class="btn" style="background:#D1FAE5;color:#059669">😊 记得</button>
      <button type="submit" name="quality" value="5" class="btn" style="background:#DBEAFE;color:#2563EB">😎 熟练</button>
    </form>
  </div>
<% } %>
