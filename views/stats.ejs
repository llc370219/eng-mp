<%- include("header") %>
<h2>📊 学习统计</h2>

<div class="card">
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px;text-align:center">
    <div style="padding:12px;background:#EEF2FF;border-radius:12px">
      <div style="font-size:24px;font-weight:700;color:#4F46E5"><%= streak %></div>
      <div style="font-size:11px;color:#6B7280">🔥 连续天数</div>
    </div>
    <div style="padding:12px;background:#F0FDF4;border-radius:12px">
      <div style="font-size:24px;font-weight:700;color:#10B981"><%= totalStudyMin %></div>
      <div style="font-size:11px;color:#6B7280">⏱ 学习分钟</div>
    </div>
    <div style="padding:12px;background:#FEF3C7;border-radius:12px">
      <div style="font-size:24px;font-weight:700;color:#F59E0B"><%= readingCompleted %></div>
      <div style="font-size:11px;color:#6B7280">📚 完成文章</div>
    </div>
    <div style="padding:12px;background:#ECFDF5;border-radius:12px">
      <div style="font-size:24px;font-weight:700;color:#059669"><%= vocabTotal %></div>
      <div style="font-size:11px;color:#6B7280">📝 生词总数</div>
    </div>
    <div style="padding:12px;background:#F5F3FF;border-radius:12px">
      <div style="font-size:24px;font-weight:700;color:#7C3AED"><%= vocabMastered %></div>
      <div style="font-size:11px;color:#6B7280">✅ 已掌握</div>
    </div>
    <div style="padding:12px;background:#FEF2F2;border-radius:12px">
      <div style="font-size:24px;font-weight:700;color:#EF4444"><%= reviewCount %></div>
      <div style="font-size:11px;color:#6B7280">⏰ 待复习</div>
    </div>
  </div>
</div>

<div class="card">
  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:12px">
    <div style="text-align:center;padding:12px;background:#F9FAFB;border-radius:8px">
      <div style="font-size:20px;font-weight:600;color:#4F46E5"><%= totalWordsRead %></div>
      <div style="font-size:11px;color:#6B7280">阅读总词数</div>
    </div>
    <div style="text-align:center;padding:12px;background:#F9FAFB;border-radius:8px">
      <div style="font-size:20px;font-weight:600;color:#4F46E5"><%= avgScore !== null ? avgScore + '%' : '-' %></div>
      <div style="font-size:11px;color:#6B7280">平均正确率</div>
    </div>
    <div style="text-align:center;padding:12px;background:#F9FAFB;border-radius:8px">
      <div style="font-size:20px;font-weight:600;color:#4F46E5"><%= wrongUnmastered %></div>
      <div style="font-size:11px;color:#6B7280">未掌握错题</div>
    </div>
    <div style="text-align:center;padding:12px;background:#F9FAFB;border-radius:8px">
      <div style="font-size:20px;font-weight:600;color:#4F46E5"><%= grammarTotal %></div>
      <div style="font-size:11px;color:#6B7280">语法知识点</div>
    </div>
  </div>
</div>

<div class="card">
  <h2>📈 掌握率</h2>
  <% const pct = vocabTotal > 0 ? Math.round(vocabMastered / vocabTotal * 100) : 0; %>
  <div style="background:#E5E7EB;border-radius:12px;height:24px;margin-top:8px;overflow:hidden">
    <div style="background:linear-gradient(90deg,#4F46E5,#7C3AED);height:100%;width:<%= pct %>%;border-radius:12px;display:flex;align-items:center;justify-content:center;color:white;font-size:12px;font-weight:600"><%= pct %>%</div>
  </div>
  <div style="display:flex;justify-content:space-between;font-size:11px;color:#6B7280;margin-top:4px">
    <span>已掌握: <%= vocabMastered %></span><span>未掌握: <%= vocabTotal - vocabMastered %></span>
  </div>
</div>

<% if (weekTrend.length > 0) { %>
<div class="card">
  <h2>📅 近7天词汇增长</h2>
  <% const maxW = Math.max(...weekTrend.map(d => d.count), 1); %>
  <svg width="100%" height="140" viewBox="0 0 <%= weekTrend.length * 60 %> 140" style="margin-top:8px">
    <% weekTrend.forEach((d, i) => { %>
      <rect x="<%= i * 60 + 15 %>" y="<%= 120 - (d.count / maxW * 90) %>" width="40" height="<%= (d.count / maxW * 90) %>" fill="url(#grad)" rx="6"/>
      <text x="<%= i * 60 + 35 %>" y="135" text-anchor="middle" font-size="11" fill="#6B7280"><%= d._id %></text>
      <text x="<%= i * 60 + 35 %>" y="<%= 115 - (d.count / maxW * 90) %>" text-anchor="middle" font-size="12" fill="#4F46E5" font-weight="600"><%= d.count %></text>
    <% }) %>
    <defs><linearGradient id="grad" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#4F46E5"/><stop offset="100%" stop-color="#818CF8"/></linearGradient></defs>
  </svg>
</div>
<% } %>

<div class="card">
  <h2>快捷操作</h2>
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:12px">
    <a href="/demo/vocab/review" class="btn btn-primary btn-sm" style="text-decoration:none;color:white">📖 复习单词</a>
    <a href="/demo/dict" class="btn btn-sm" style="background:white;border:1px solid #E5E7EB;text-decoration:none;color:#111827">🔍 查词典</a>
    <a href="/demo/" class="btn btn-sm" style="background:white;border:1px solid #E5E7EB;text-decoration:none;color:#111827">📚 读文章</a>
    <a href="/demo/grammar" class="btn btn-sm" style="background:white;border:1px solid #E5E7EB;text-decoration:none;color:#111827">📐 学语法</a>
    <a href="/demo/ai" class="btn btn-sm" style="background:white;border:1px solid #E5E7EB;text-decoration:none;color:#111827">🤖 AI 助手</a>
  </div>
</div>
<%- include("footer") %>
