<h2>📊 学习统计</h2>
<div class="card">
  <div class="stat-grid">
    <div class="stat-item"><div class="stat-val"><%= vocabCount %></div><div class="stat-lbl">生词总数</div></div>
    <div class="stat-item"><div class="stat-val"><%= masteredCount %></div><div class="stat-lbl">已掌握</div></div>
    <div class="stat-item"><div class="stat-val"><%= reviewCount %></div><div class="stat-lbl">待复习</div></div>
    <div class="stat-item"><div class="stat-val">-</div><div class="stat-lbl">连续天数</div></div>
  </div>
</div>
<div class="card">
  <h2>快捷操作</h2>
  <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:12px">
    <a href="/demo/vocab/review" class="btn btn-primary btn-sm" style="text-decoration:none;color:white">📖 复习单词</a>
    <a href="/demo/dict" class="btn btn-sm" style="background:white;border:1px solid #E5E7EB;text-decoration:none;color:#111827">🔍 查词典</a>
    <a href="/demo/" class="btn btn-sm" style="background:white;border:1px solid #E5E7EB;text-decoration:none;color:#111827">📚 读文章</a>
  </div>
</div>
