<%- include("header") %>
<h1>⚙️ 系统设置</h1>
<form method="POST" action="/admin/settings">
<div class="card">
  <h2>基本设置</h2>
  <div class="form-row"><label>站点名称</label><input type="text" name="siteName" value="<%= settings.siteName || '' %>"></div>
  <div class="form-row"><label>默认用户等级</label>
    <select name="defaultUserLevel">
      <% ['A1','A2','B1','B2','C1','C2'].forEach(l => { %><option value="<%= l %>" <%= settings.defaultUserLevel===l?'selected':'' %>><%= l %></option><% }) %>
    </select>
  </div>
  <div class="form-row"><label>打卡最低学习分钟</label><input type="number" name="dailyCheckInMin" value="<%= settings.dailyCheckInMin || 5 %>"></div>
</div>
<div class="card">
  <h2>注册设置</h2>
  <div class="form-row"><label>开放注册</label>
    <select name="allowRegistration"><option value="true" <%= settings.allowRegistration!==false?'selected':'' %>>是</option><option value="false" <%= settings.allowRegistration===false?'selected':'' %>>否</option></select>
  </div>
  <div class="form-row"><label>需要邀请码</label>
    <select name="requireInviteCode"><option value="true" <%= settings.requireInviteCode!==false?'selected':'' %>>是</option><option value="false" <%= settings.requireInviteCode===false?'selected':'' %>>否</option></select>
  </div>
</div>
<div class="card">
  <h2>🤖 AI 设置</h2>
  <div class="form-row"><label>开启 AI 鲜榨文章生成</label>
    <select name="enableAIGeneration">
      <option value="true" <%= settings.enableAIGeneration!==false?'selected':'' %>>开启</option>
      <option value="false" <%= settings.enableAIGeneration===false?'selected':'' %>>关闭</option>
    </select>
  </div>
  <div class="form-row"><label>默认 AI 提供商</label>
    <select name="aiProvider" id="aiProviderSelect">
      <% ['deepseek','mimo','openai','claude','moonshot','zhipu','qwen','ark'].forEach(p => { %><option value="<%= p %>" <%= settings.aiProvider===p?'selected':'' %>><%= p %></option><% }) %>
    </select>
  </div>
  <div class="form-row"><label>AI 模型（留空使用提供商默认模型）</label>
    <input type="text" name="aiModel" value="<%= settings.aiModel || '' %>" placeholder="例如 doubao-seed-1-6-flash-250615、deepseek-chat、gpt-4o-mini">
  </div>
  <div class="form-row"><label>最大 Token 数</label>
    <input type="number" name="aiMaxTokens" value="<%= settings.aiMaxTokens || 2048 %>" min="256" max="65536" step="256">
  </div>
</div>

<div class="card">
  <h2>🔑 API Key 管理</h2>
  <p style="font-size:12px;color:#6B7280;margin-bottom:16px">留空表示不修改已有配置。配置保存后立即生效，无需重启服务。</p>
  <%
    const providerList = [
      { key: 'ark', name: '火山方舟 (豆包)', url: 'https://www.volcengine.com/' },
      { key: 'deepseek', name: 'DeepSeek', url: 'https://platform.deepseek.com' },
      { key: 'mimo', name: 'MiMo', url: 'https://mimo.ai' },
      { key: 'openai', name: 'OpenAI', url: 'https://platform.openai.com' },
      { key: 'claude', name: 'Claude (Anthropic)', url: 'https://console.anthropic.com' },
      { key: 'moonshot', name: 'Moonshot (Kimi)', url: 'https://platform.moonshot.cn' },
      { key: 'zhipu', name: '智谱 (GLM)', url: 'https://open.bigmodel.cn' },
      { key: 'qwen', name: '通义千问', url: 'https://dashscope.console.aliyun.com' },
    ];
  %>
  <% providerList.forEach((p, i) => { %>
  <div style="display:flex;align-items:center;gap:12px;margin-bottom:12px;padding:12px;background:#F9FAFB;border-radius:8px;border:1px solid #E5E7EB">
    <div style="min-width:140px">
      <strong style="font-size:13px"><%= p.name %></strong>
      <div style="font-size:11px;color:#6B7280">
        <% if (settings['aiApiKey_' + p.key]) { %>
          <span style="color:#10B981">✅ 已配置</span>
        <% } else { %>
          <span style="color:#EF4444">❌ 未配置</span>
        <% } %>
      </div>
    </div>
    <div style="flex:1;position:relative">
      <input type="password" name="aiApiKey_<%= p.key %>" id="key_<%= p.key %>"
        placeholder="<%= settings['aiApiKey_' + p.key] ? '已配置（留空不修改）' : '输入 API Key' %>"
        style="width:100%;padding:8px 36px 8px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:13px;font-family:monospace">
      <button type="button" onclick="toggleKey('<%= p.key %>')" style="position:absolute;right:4px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:16px;padding:4px" title="显示/隐藏">👁</button>
    </div>
    <button type="button" class="btn btn-sm" style="background:#6366F1;color:white;white-space:nowrap" onclick="testAI('<%= p.key %>')">🧪 测试</button>
  </div>
  <% }) %>
  <div id="testResult" style="display:none;margin-top:8px;padding:10px;border-radius:8px;font-size:13px"></div>
</div>
<div class="card">
  <h2>系统</h2>
  <div class="form-row"><label>维护模式</label>
    <select name="maintenanceMode"><option value="false" <%= !settings.maintenanceMode?'selected':'' %>>关闭</option><option value="true" <%= settings.maintenanceMode?'selected':'' %>>开启</option></select>
  </div>
</div>
<button type="submit" class="btn btn-primary" style="padding:12px 32px;font-size:14px">保存设置</button>
</form>

<script>
function toggleKey(provider) {
  const input = document.getElementById('key_' + provider);
  input.type = input.type === 'password' ? 'text' : 'password';
}

async function testAI(provider) {
  const resultDiv = document.getElementById('testResult');
  resultDiv.style.display = 'block';
  resultDiv.style.background = '#E0E7FF';
  resultDiv.style.color = '#3730A3';
  resultDiv.textContent = '⏳ 正在测试 ' + provider + ' 连接...';

  try {
    const resp = await fetch('/admin/settings/test-ai', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ provider }),
    });
    const data = await resp.json();

    if (data.ok) {
      resultDiv.style.background = '#D1FAE5';
      resultDiv.style.color = '#059669';
      resultDiv.textContent = '✅ ' + provider + ' 连接成功：' + data.message;
    } else {
      resultDiv.style.background = '#FEE2E2';
      resultDiv.style.color = '#DC2626';
      resultDiv.textContent = '❌ ' + provider + ' 连接失败：' + data.message;
    }
  } catch (err) {
    resultDiv.style.background = '#FEE2E2';
    resultDiv.style.color = '#DC2626';
    resultDiv.textContent = '❌ 请求失败：' + err.message;
  }
}
</script>
<%- include("footer") %>