<%- include("header") %>
<h1>📈 统计报表</h1>
<div class="stat-grid">
  <div class="stat-item"><div class="stat-val"><%= totalStudyMin %></div><div class="stat-lbl">总学习分钟</div></div>
  <div class="stat-item"><div class="stat-val"><%= avgStudyMin %></div><div class="stat-lbl">人均学习分钟</div></div>
  <div class="stat-item"><div class="stat-val"><%= totalReads %></div><div class="stat-lbl">总完成文章</div></div>
  <div class="stat-item"><div class="stat-val"><%= totalWordsRead %></div><div class="stat-lbl">总阅读词数</div></div>
  <div class="stat-item"><div class="stat-val"><%= totalVocab %></div><div class="stat-lbl">总生词数</div></div>
  <div class="stat-item"><div class="stat-val"><%= totalExercises %></div><div class="stat-lbl">总练习次数</div></div>
  <div class="stat-item"><div class="stat-val"><%= weeklyActive %></div><div class="stat-lbl">本周活跃</div></div>
  <div class="stat-item"><div class="stat-val"><%= monthlyActive %></div><div class="stat-lbl">本月活跃</div></div>
</div>
<div class="card">
  <h2>热门文章 Top 10</h2>
  <table><tr><th>排名</th><th>文章</th><th>阅读次数</th></tr>
  <% topArticles.forEach((a, i) => { %>
  <tr><td><%= i+1 %></td><td><%= a.article[0] ? a.article[0].title : '-' %></td><td><%= a.count %></td></tr>
  <% }) %>
  <% if (!topArticles.length) { %><tr><td colspan="3" style="text-align:center;color:#6B7280">暂无数据</td></tr><% } %>
  </table>
</div>
<div class="card">
  <h2>热门词汇 Top 10</h2>
  <table><tr><th>排名</th><th>单词</th><th>添加次数</th></tr>
  <% topWords.forEach((w, i) => { %>
  <tr><td><%= i+1 %></td><td style="font-weight:600"><%= w._id %></td><td><%= w.count %></td></tr>
  <% }) %>
  <% if (!topWords.length) { %><tr><td colspan="3" style="text-align:center;color:#6B7280">暂无数据</td></tr><% } %>
  </table>
</div>
<%- include("footer") %>