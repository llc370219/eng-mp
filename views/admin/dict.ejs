<%- include("header") %>
<h1>📖 词典管理</h1>
<form method="GET" action="/admin/dict" style="display:flex;gap:8px;margin-bottom:16px">
  <input type="text" name="search" value="<%= search %>" placeholder="搜索单词" style="padding:8px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:13px">
  <button type="submit" class="btn btn-primary">搜索</button>
</form>
<div class="card">
  <table>
    <tr><th>单词</th><th>音标</th><th>释义</th><th>标签</th></tr>
    <% dicts.forEach(d => { %>
    <tr>
      <td style="font-weight:600"><%= d.word %></td>
      <td><%= d.phonetic || '-' %></td>
      <td><%= d.translation || d.definitionEn || '-' %></td>
      <td><span class="badge badge-diff"><%= d.tag || '-' %></span></td>
    </tr>
    <% }) %>
  </table>
</div>
<%- include("footer") %>