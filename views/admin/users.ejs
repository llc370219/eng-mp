<%- include("header") %>
<h1>👥 用户管理</h1>
<form method="GET" action="/admin/users" style="display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap">
  <input type="text" name="search" value="<%= search %>" placeholder="搜索邮箱/昵称" style="padding:8px 12px;border:1px solid #D1D5DB;border-radius:6px;font-size:13px">
  <select name="level" style="padding:8px;border:1px solid #D1D5DB;border-radius:6px;font-size:13px">
    <option value="">全部等级</option>
    <% ['A1','A2','B1','B2','C1','C2'].forEach(l => { %><option value="<%= l %>" <%= level===l?'selected':'' %>><%= l %></option><% }) %>
  </select>
  <select name="role" style="padding:8px;border:1px solid #D1D5DB;border-radius:6px;font-size:13px">
    <option value="">全部角色</option>
    <option value="user" <%= role==='user'?'selected':'' %>>user</option>
    <option value="editor" <%= role==='editor'?'selected':'' %>>editor</option>
    <option value="admin" <%= role==='admin'?'selected':'' %>>admin</option>
  </select>
  <button type="submit" class="btn btn-primary">筛选</button>
</form>
<div class="card">
  <table>
    <tr><th>邮箱</th><th>昵称</th><th>等级</th><th>角色</th><th>注册时间</th><th>最后登录</th><th>操作</th></tr>
    <% users.forEach(u => { %>
    <tr>
      <td><%= u.email %></td>
      <td><%= u.nickname || '-' %></td>
      <td><span class="badge badge-diff"><%= u.level %></span></td>
      <td><span class="badge badge-role"><%= u.role %></span></td>
      <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
      <td><%= u.lastLoginAt ? new Date(u.lastLoginAt).toLocaleDateString() : '-' %></td>
      <td><a href="/admin/users/<%= u._id %>" class="btn btn-primary btn-sm">详情</a></td>
    </tr>
    <% }) %>
  </table>
</div>
<div style="display:flex;gap:8px;justify-content:center;margin-top:16px">
  <% if (page > 1) { %><a href="?page=<%= page-1 %>&search=<%= search %>&level=<%= level %>&role=<%= role %>" class="btn btn-primary btn-sm">上一页</a><% } %>
  <span style="padding:6px 12px;font-size:13px;color:#6B7280">第 <%= page %> 页 / 共 <%= Math.ceil(total/limit) %> 页</span>
  <% if (page < Math.ceil(total/limit)) { %><a href="?page=<%= page+1 %>&search=<%= search %>&level=<%= level %>&role=<%= role %>" class="btn btn-primary btn-sm">下一页</a><% } %>
</div>
<%- include("footer") %>