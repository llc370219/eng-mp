<%- include("header") %>
<h1>📚 文章管理</h1>

<% if (typeof importMsg !== 'undefined' && importMsg) { %>
  <div class="card" style="margin-bottom:16px;border-left:4px solid #2f7fd6;font-weight:600"><%= importMsg %></div>
<% } %>

<!-- 上传 article-maker skill 生成的压缩包，一键发布推送 -->
<div class="card" style="margin-bottom:16px;background:#f8fafc">
  <div style="font-weight:700;margin-bottom:8px">📦 导入文章包（鲜榨工坊 / article-maker skill 生成）</div>
  <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap">
    <input type="file" id="pkgFile" accept=".zip,.json" style="font-size:13px">
    <label style="font-size:13px;display:flex;align-items:center;gap:5px"><input type="checkbox" id="pkgPublish" checked> 导入后立即发布推送</label>
    <button type="button" class="btn btn-primary" id="pkgBtn" onclick="uploadPkg()">导入并发布</button>
    <span id="pkgStatus" style="font-size:13px;color:#6B7280"></span>
  </div>
  <div style="font-size:12px;color:#6B7280;margin-top:8px">支持 .zip（内含 articles.json）或直接 .json。包含正文、逐句翻译、语法、生词、测验等全部内容。</div>
</div>
<script>
async function uploadPkg(){
  var f=document.getElementById('pkgFile').files[0];
  var status=document.getElementById('pkgStatus');
  if(!f){ status.textContent='请先选择文件'; return; }
  var publish=document.getElementById('pkgPublish').checked;
  document.getElementById('pkgBtn').disabled=true; status.textContent='上传中…';
  try{
    var res=await fetch('/admin/articles/import?publish='+publish+'&name='+encodeURIComponent(f.name),{method:'POST',headers:{'Content-Type':'application/octet-stream'},body:f});
    var data=await res.json();
    status.textContent=data.message||data.error||'完成';
    if(res.ok){ setTimeout(function(){ location.href='/admin/articles'; },800); }
  }catch(e){ status.textContent='上传失败: '+e.message; }
  document.getElementById('pkgBtn').disabled=false;
}
</script>

<form method="GET" action="/admin/articles" style="display:flex;gap:8px;margin-bottom:16px">
  <select name="difficulty" style="padding:8px;border:1px solid #D1D5DB;border-radius:6px;font-size:13px">
    <option value="">全部难度</option>
    <% ['初中','高中','CET4','CET6','考研','雅思'].forEach(d => { %><option value="<%= d %>" <%= difficulty===d?'selected':'' %>><%= d %></option><% }) %>
  </select>
  <button type="submit" class="btn btn-primary">筛选</button>
</form>
<div class="card">
  <table>
    <tr><th>标题</th><th>难度</th><th>分类</th><th>字数</th><th>状态</th><th>操作</th></tr>
    <% articles.forEach(a => { %>
    <tr>
      <td><%= a.title %></td>
      <td><span class="badge badge-diff"><%= a.difficulty %></span></td>
      <td><span class="badge badge-cat"><%= a.category %></span></td>
      <td><%= a.wordCount %></td>
      <td><%= a.isPublished ? '✅ 已发布' : '⏸ 未发布' %></td>
      <td>
        <form method="POST" action="/admin/articles/<%= a._id %>/toggle" style="display:inline"><button type="submit" class="btn btn-warning btn-sm"><%= a.isPublished ? '下架' : '发布' %></button></form>
        <form method="POST" action="/admin/articles/<%= a._id %>/delete" style="display:inline"><button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('确定删除？')">删除</button></form>
      </td>
    </tr>
    <% }) %>
  </table>
</div>
<%- include("footer") %>