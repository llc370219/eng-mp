# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/eng-reader

# JWT
JWT_SECRET=change-this-to-a-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-to-another-random-secret
JWT_REFRESH_EXPIRES_IN=7d

# AI Provider (openai / claude / deepseek / mimo / moonshot / zhipu / qwen)
AI_PROVIDER=deepseek
AI_MODEL=
AI_MAX_TOKENS=2048

# AI API Keys (配置你要使用的 provider)
OPENAI_API_KEY=
CLAUDE_API_KEY=
DEEPSEEK_API_KEY=
MIMO_API_KEY=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=
QWEN_API_KEY=

# Dictionary API
DICT_API_URL=https://api.dictionaryapi.dev/api/v2/entries/en

# SMTP (邮件服务，用于发送验证码)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@eng-reader.com

# CORS (production only, comma separated)
ALLOWED_ORIGINS=

# 彩云小译 LingoCloud（词典+翻译）— 从 https://dashboard.caiyunapp.com 申请
CAIYUN_TOKEN=

# 火山方舟·豆包（鲜榨工坊默认）— AI_PROVIDER=ark
ARK_API_KEY=
